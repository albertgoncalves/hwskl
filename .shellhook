#!/usr/bin/env bash

export WD=$PWD

for dir in bin build out; do
    if [ ! -d "$WD/$dir" ]; then
        mkdir "$WD/$dir"
    fi
done

export FLAGS=(
    "-fdiagnostics-color=always"
    -fprof-auto
    -fprof-cafs
    -funbox-strict-fields
    "-optl-fuse-ld=lld"
    "-outputdir $WD/build"
    -prof
    -Wall
    -Wcompat
    -Werror
    -Widentities
    -Wincomplete-record-updates
    -Wincomplete-uni-patterns
    -Wmissing-export-lists
    -Wmonomorphism-restriction
    -Wno-name-shadowing
    -Wno-unused-top-binds
    -Wno-x-partial
    -Wpartial-fields
    -Wunused-packages
    -Wunused-type-patterns
)

lint () {
    hlint "$1"
    ormolu -i --no-cabal "$1"
}

runh () {
    handle=$(basename "${1%%.*}")
    (
        if [ "$(ls -A "$WD/build")" ]; then
            rm "$WD/build"/*
        fi
        cd "$WD/src" || return
        ghc "${FLAGS[@]}" -o "$WD/bin/$handle" "$handle.hs" || return
        cd "$WD" || return
        "$WD/bin/$handle" +RTS -xc -RTS
    )
}

export -f lint
export -f runh
